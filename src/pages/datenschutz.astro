    padding-top: clamp(60px, 8vw, 110px);
    padding-bottom: clamp(60px, 8vw, 110px);
  }
  .legal-inner {
    max-width: 70ch;
    margin: 0 auto;
  }
  .legal :global(h1) {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(40px, 6vw, 64px);
    line-height: 1;
    letter-spacing: -0.015em;
    margin: 0 0 12px 0;
  }
  .legal-lede {
    font-family: var(--sans);
    font-size: 14px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 clamp(40px, 5vw, 56px) 0;
    max-width: none;
  }
  .legal :global(h2) {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(22px, 2.4vw, 28px);
    line-height: 1.2;
    letter-spacing: -0.005em;
    margin: clamp(32px, 4vw, 48px) 0 12px 0;
    scroll-margin-top: 80px;
  }
  .legal :global(h3) {
    font-family: var(--sans);
    font-size: 14px;
    font-weight: 600;
    line-height: 1.4;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 24px 0 8px 0;
  }
  .legal :global(p) {
    font-size: 16px;
    line-height: 1.7;
    color: var(--ink-2);
    margin: 0 0 1em 0;
    max-width: none;
  }
  .legal :global(ul) {
    margin: 0 0 1em 0;
    padding-left: 20px;
    list-style: disc;
  }
  .legal :global(ul li) {
    font-size: 16px;
    line-height: 1.7;
    color: var(--ink-2);
    margin-bottom: 6px;
  }
  .legal :global(strong) {
    font-weight: 500;
    color: var(--ink);
  }
  .legal :global(a) {
    color: var(--accent);
    word-break: break-word;
  }
  .legal :global(a:hover) {
    opacity: 0.7;
  }
  .legal-toc {
    margin: 0 0 clamp(40px, 5vw, 56px) 0;
    padding-left: 20px;
  }
  .legal-toc :global(li) {
    margin-bottom: 4px;
  }
  .legal-toc :global(a) {
    color: var(--ink-2);
    text-decoration: none;
    border-bottom: 1px solid var(--rule-soft);
  }
  .legal-toc :global(a:hover) {
    color: var(--accent);
    border-bottom-color: var(--accent);
    opacity: 1;
  }
</style>
