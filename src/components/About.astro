---
import { Image } from 'astro:assets';
import portraitImg from '../assets/about-portrait.jpg';
import { t, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'de' } = Astro.props;
const copy = t(lang).about;
---
<section class="section" id="uber">
  <div class="about">
    <div class="about-head">
      <div class="kicker">{copy.kicker}</div>
      <h2 class="about-statement">{copy.statement}</h2>
    </div>
    <div class="about-text">
      <p class="about-subline">{copy.subline}</p>
      {copy.paragraphsHtml.map((html) => <p set:html={html}></p>)}
    </div>
    <div class="about-img">
      <Image
        src={portraitImg}
        alt={copy.imageAlt}
        widths={[380, 480, 640, 760]}
        sizes="(max-width: 880px) 380px, 40vw"
        format="webp"
        quality={85}
        loading="lazy"
      />
    </div>
  </div>
</section>

<style>
  /* Two-row grid: kicker+statement on top (col 1 only, image col empty),
     then subline+body | image side-by-side. Image dimensions are set by JS
     so its height matches the text exactly; CSS provides the default fallback. */
  .about {
    display: grid;
    grid-template-columns: minmax(0, 60ch) auto;
    grid-template-areas:
      "head ."
      "text img";
    column-gap: clamp(16px, 2.5vw, 40px);
    row-gap: clamp(20px, 2.6vw, 32px);
    align-items: start;
    justify-content: center;
  }
  .about-head {
    grid-area: head;
    max-width: 64ch;
  }
  .about-text {
    grid-area: text;
    max-width: 64ch;
    font-size: 16px;
    line-height: 1.65;
  }
  .about-text :global(p) { color: var(--ink-2); }
  /* Statement — serif display headline. */
  .about-head :global(.about-statement) {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(36px, 5vw, 56px);
    line-height: 1;
    letter-spacing: -0.015em;
    color: var(--ink);
    max-width: none;
    margin: 0;
  }
  /* Subline — sits as the lede of the body column; spacing to body via margin. */
  .about-text :global(.about-subline) {
    font-family: var(--sans);
    font-size: clamp(17px, 1.5vw, 20px);
    font-weight: 400;
    line-height: 1.5;
    color: var(--ink);
    max-width: none;
    margin: 0 0 clamp(24px, 3vw, 36px) 0;
  }
  /* Image: dimensions set dynamically via JS (height = text body height,
     width = height × 4/5). CSS fallback if JS hasn't run yet keeps the
     portrait at its native 4:5 framing. max-width:100% prevents the
     image from overflowing its grid column on narrow viewports. */
  .about-img {
    grid-area: img;
    aspect-ratio: 4 / 5;
    width: 380px;
    max-width: 100%;
    background: var(--paper-2);
    position: relative;
    overflow: hidden;
  }
  .about-img :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  @media (max-width: 880px) {
    .about {
      grid-template-columns: 1fr;
      grid-template-areas: "head" "text" "img";
    }
    .about-img { aspect-ratio: 3 / 4; height: auto; max-width: 380px; }
  }
</style>
